# Copia a ".env" en la raíz del repositorio (junto a docker-compose.yml).
# Docker Compose carga ".env" automáticamente para sustituir variables.

# Dominios públicos (DNS → IP del servidor antes de levantar Traefik).
# Los A de @ y api deben apuntar a la IP pública del VPS. VITE_API_URL debe
# coincidir con NO_SIGNAL_API_DOMAIN (https://…).
# Namecheap: usar "Namecheap BasicDNS", no "Custom DNS" con los mismos NS,
# para que Advanced DNS sea la zona autoritativa (evita IP parking / login roto).
NO_SIGNAL_APP_DOMAIN=huertas.nosignal.site
NO_SIGNAL_API_DOMAIN=api.huertas.nosignal.site

# Let's Encrypt (email real obligatorio en producción)
ACME_EMAIL=admin@tudominio.com

# Origen(es) del SPA para CORS del backend (coma si hay varios). NO es la URL del API.
# Ej. si el sitio abre en https://tudominio.com y https://www.tudominio.com:
# CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com
CORS_ORIGINS=https://huertas.nosignal.site

# Secretos obligatorios (no usar valores por defecto inseguros en producción)
# Genera JWT_SECRET con al menos 32 caracteres aleatorios.
ENVIRONMENT=production
JWT_SECRET=REEMPLAZAR_CON_SECRETO_LARGO_Y_ALEATORIO
# Duración del token de login (minutos). 525600 ≈ 1 año. Docker Compose lee esto desde este .env.
JWT_EXPIRES_MINUTES=525600
POSTGRES_PASSWORD=REEMPLAZAR_PASSWORD_DB
# JSON de usuarios para login MVP. Formatos aceptados:
# - bcrypt: "$2b$..."
# - plain temporal: "plain:tu_clave" (evitar en producción)
NOSIGNAL_AUTH_USERS={"admin":"REEMPLAZAR_HASH_BCRYPT"}
# Solo para desarrollo local: permite defaults inseguros en backend (no en producción).
ALLOW_INSECURE_DEFAULTS=false
AUTO_CREATE_SCHEMA=false

# URL absoluta del API en el build del frontend (UNA sola URL; debe coincidir con NO_SIGNAL_API_DOMAIN).
# Correcto:  VITE_API_URL=https://api.huertas.nosignal.site
# Incorrecto: VITE_API_URL=https://api.huertas.nosignal.site,https://www.tudominio.com  (eso es CORS_ORIGINS, no esto)
VITE_API_URL=https://api.huertas.nosignal.site

# Opcional: solo si necesitás salirte de la DB local del compose de Huertas.
# Por defecto el backend usa: postgresql+asyncpg://nosignal:<POSTGRES_PASSWORD>@db:5432/nosignal
# HUERTAS_DATABASE_URL=postgresql+asyncpg://nosignal:REEMPLAZAR_PASSWORD_DB@db:5432/nosignal
